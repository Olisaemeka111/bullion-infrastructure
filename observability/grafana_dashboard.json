{
  "title": "Cluster Infra — Fleet Lifecycle & Health",
  "uid": "clusterinfra-fleet",
  "schemaVersion": 39,
  "editable": true,
  "tags": ["cluster-infra", "lifecycle", "fleet"],
  "time": { "from": "now-6h", "to": "now" },
  "refresh": "30s",
  "templating": {
    "list": [
      {
        "name": "cluster",
        "type": "query",
        "query": "label_values(clusterinfra_nodes, cluster)",
        "includeAll": true,
        "multi": true
      },
      {
        "name": "provider",
        "type": "query",
        "query": "label_values(clusterinfra_nodes, provider)",
        "includeAll": true,
        "multi": true
      }
    ]
  },
  "panels": [
    {
      "id": 1,
      "title": "Total HEALTHY nodes",
      "type": "stat",
      "gridPos": { "h": 4, "w": 4, "x": 0, "y": 0 },
      "targets": [
        { "expr": "sum(clusterinfra_pool_healthy_nodes{cluster=~\"$cluster\"})" }
      ]
    },
    {
      "id": 2,
      "title": "Total DESIRED nodes",
      "type": "stat",
      "gridPos": { "h": 4, "w": 4, "x": 4, "y": 0 },
      "targets": [
        { "expr": "sum(clusterinfra_pool_desired_nodes{cluster=~\"$cluster\"})" }
      ]
    },
    {
      "id": 3,
      "title": "Fleet availability (healthy/desired)",
      "type": "gauge",
      "gridPos": { "h": 4, "w": 4, "x": 8, "y": 0 },
      "fieldConfig": {
        "defaults": {
          "min": 0, "max": 1, "unit": "percentunit",
          "thresholds": { "steps": [
            { "color": "red", "value": 0 },
            { "color": "yellow", "value": 0.9 },
            { "color": "green", "value": 0.99 }
          ] }
        }
      },
      "targets": [
        { "expr": "sum(clusterinfra_pool_healthy_nodes) / sum(clusterinfra_pool_desired_nodes)" }
      ]
    },
    {
      "id": 4,
      "title": "Security gate rejections (10m)",
      "type": "stat",
      "gridPos": { "h": 4, "w": 4, "x": 12, "y": 0 },
      "fieldConfig": { "defaults": { "thresholds": { "steps": [
        { "color": "green", "value": 0 }, { "color": "red", "value": 1 } ] } } },
      "targets": [
        { "expr": "sum(increase(clusterinfra_security_gate_rejections_total[10m]))" }
      ]
    },
    {
      "id": 5,
      "title": "Reconcile ticks/min",
      "type": "stat",
      "gridPos": { "h": 4, "w": 4, "x": 16, "y": 0 },
      "targets": [
        { "expr": "sum(rate(clusterinfra_reconcile_ticks_total[1m])) * 60" }
      ]
    },
    {
      "id": 6,
      "title": "Self-heals/min",
      "type": "stat",
      "gridPos": { "h": 4, "w": 4, "x": 20, "y": 0 },
      "targets": [
        { "expr": "sum(rate(clusterinfra_self_heal_total[5m])) * 60" }
      ]
    },
    {
      "id": 10,
      "title": "Nodes by lifecycle state",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 4 },
      "options": { "stacking": { "mode": "normal" } },
      "targets": [
        { "expr": "sum(clusterinfra_nodes{cluster=~\"$cluster\",provider=~\"$provider\"}) by (state)",
          "legendFormat": "{{state}}" }
      ]
    },
    {
      "id": 11,
      "title": "Healthy nodes by provider",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 4 },
      "options": { "stacking": { "mode": "normal" } },
      "targets": [
        { "expr": "sum(clusterinfra_pool_healthy_nodes{cluster=~\"$cluster\"}) by (provider)",
          "legendFormat": "{{provider}}" }
      ]
    },
    {
      "id": 12,
      "title": "Pool availability ratio",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 12 },
      "fieldConfig": { "defaults": { "min": 0, "max": 1, "unit": "percentunit" } },
      "targets": [
        { "expr": "clusterinfra_pool_availability_ratio{cluster=~\"$cluster\",provider=~\"$provider\"}",
          "legendFormat": "{{cluster}}/{{pool}}" }
      ]
    },
    {
      "id": 13,
      "title": "Node failures/min by reason",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 12 },
      "targets": [
        { "expr": "sum(rate(clusterinfra_nodes_failed_total[5m])) by (reason) * 60",
          "legendFormat": "{{reason}}" }
      ]
    },
    {
      "id": 14,
      "title": "Provisioning throughput (nodes created/min by provider)",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 20 },
      "targets": [
        { "expr": "sum(rate(clusterinfra_nodes_created_total[5m])) by (provider) * 60",
          "legendFormat": "{{provider}}" }
      ]
    },
    {
      "id": 15,
      "title": "Reconcile actions/min by type",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 20 },
      "targets": [
        { "expr": "sum(rate(clusterinfra_reconcile_actions_total[5m])) by (type) * 60",
          "legendFormat": "{{type}}" }
      ]
    },
    {
      "id": 16,
      "title": "Decommissioned nodes (cumulative)",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 24, "x": 0, "y": 28 },
      "targets": [
        { "expr": "sum(clusterinfra_nodes_terminated_total) by (provider)",
          "legendFormat": "{{provider}}" }
      ]
    }
  ]
}
